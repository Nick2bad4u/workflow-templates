{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "workflow-templates",
    "private": true,
    "description": "GitHub Actions workflow template repository.",
    "keywords": [
        "github-actions",
        "workflow-templates",
        "template-repository"
    ],
    "homepage": "https://github.com/Nick2bad4u/workflow-templates",
    "bugs": {
        "url": "https://github.com/Nick2bad4u/workflow-templates/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Nick2bad4u/workflow-templates.git"
    },
    "license": "MIT",
    "author": "Nick2bad4u <20943337+Nick2bad4u@users.noreply.github.com> (https://github.com/Nick2bad4u)",
    "scripts": {
        "build": "npm run build:runtime",
        "changelog:generate": "npx git-cliff --config cliff.toml --output CHANGELOG.md",
        "changelog:preview": "npx git-cliff --config cliff.toml --unreleased",
        "changelog:release-notes": "npx git-cliff --config cliff.toml --current --strip all",
        "docs:actions:check": "node ./scripts/action-readmes.mjs",
        "docs:actions:update": "node ./scripts/action-readmes.mjs --write",
        "format": "npx prettier . --write",
        "format:check": "npx prettier . --check",
        "lint": "npx cross-env NODE_OPTIONS=--max_old_space_size=8192 npx eslint . --cache --cache-strategy content --cache-location .cache/.eslintcache",
        "lint:actions": "actionlint -config-file ActionLintConfig.yaml",
        "lint:all": "npm run lint && npm run format:check && npm run lint:gitleaks && npm run lint:yamllint",
        "lint:all:fix": "npm run lint:fix && npm run lint:remark:fix && npm run format",
        "lint:fix": "npx cross-env NODE_OPTIONS=--max_old_space_size=8192 npx eslint . --cache --cache-strategy content --cache-location .cache/.eslintcache --fix",
        "lint:gitleaks": "gitleaks dir --config .gitleaks.toml .",
        "lint:package-json": "npmPkgJsonLint . --config .npmpackagejsonlintrc.json",
        "lint:prettier": "npx prettier . --log-level warn --cache --cache-location=.cache/.prettier-cache --cache-strategy=content --check",
        "lint:prettier:fix": "npx prettier . --log-level warn --cache --cache-location=.cache/.prettier-cache --cache-strategy=content --write",
        "lint:publint": "npx publint",
        "lint:remark": "remark . --frail --ignore-path .remarkignore",
        "lint:remark:fix": "remark . --ignore-path .remarkignore --output",
        "lint:secretlint": "npx secretlint --secretlintrc .secretlintrc.cjs --secretlintignore .gitignore \"**/*\"",
        "lint:yamllint": "yamllint -c .yamllint .",
        "schema:check:workflow-template-properties": "node ./scripts/update-workflow-template-properties-schema.mjs && git diff --exit-code -- schemas/github-workflow-template-properties.schema.json",
        "schema:test:workflow-template-properties": "node ./scripts/validate-workflow-template-properties-schema-fixtures.mjs",
        "schema:update:workflow-template-properties": "node ./scripts/update-workflow-template-properties-schema.mjs",
        "typecheck": "npx tsc -p tsconfig.js.json --noEmit",
        "update-actions": "npx actions-up --yes --style sha",
        "update-deps": "npx ncu -i --install never && npm update --all --force && npm install --force"
    },
    "devDependencies": {
        "@microsoft/tsdoc-config": "^0.18.1",
        "ajv": "^8.20.0",
        "eslint-config-nick2bad4u": "^3.0.3",
        "gitleaks-config-nick2bad4u": "^1.0.2",
        "npm-package-json-lint": "^10.4.1",
        "npm-package-json-lint-config-nick2bad4u": "^1.0.3",
        "prettier": "^3.9.1",
        "prettier-config-nick2bad4u": "^1.0.19",
        "remark": "^15.0.1",
        "remark-cli": "^12.0.1",
        "remark-config-nick2bad4u": "^1.1.2",
        "secretlint": "^13.0.2",
        "secretlint-config-nick2bad4u": "^1.1.0",
        "tsdoc-config-nick2bad4u": "^1.0.5",
        "yamllint-config-nick2bad4u": "^1.1.0"
    },
    "packageManager": "npm@11.17.0",
    "engines": {
        "node": ">=22.18.0"
    }
}
