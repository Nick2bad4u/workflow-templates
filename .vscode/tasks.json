{
    "$schema": "vscode://schemas/tasks",
    "tasks": [
        {
            "label": "Lint",
            "type": "npm",
            "script": "lint",
            "group": "test",
            "detail": "Checks repository formatting with Prettier.",
            "isBackground": false,
            "problemMatcher": []
        },
        {
            "label": "Lint:Fix",
            "type": "npm",
            "script": "lint:fix",
            "group": "test",
            "detail": "Applies repository formatting with Prettier.",
            "isBackground": false,
            "problemMatcher": []
        },
        {
            "label": "Install Dependencies (UpdateDeps)",
            "type": "npm",
            "script": "update-deps",
            "group": "build",
            "detail": "Interactively updates package versions and reinstalls dependencies.",
            "isBackground": false,
            "problemMatcher": []
        }
    ]
}
